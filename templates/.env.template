# =============================================================================
# Base Agents - Environment Configuration Template
# =============================================================================
#
# This template provides configuration for *-agents repositories that use
# base-agents as a submodule. Copy this file to your project's .env and
# customize for your tenant.
#
# Usage:
#   1. Copy to your *-agents repo root: cp base/templates/.env.template .env
#   2. Fill in credentials (marked with YOUR_*)
#   3. Customize tenant-specific settings
#   4. Never commit .env to version control
#
# =============================================================================

# =============================================================================
# TENANT IDENTIFICATION
# =============================================================================
# These identify your project/tenant for multi-tenant agent deployments

TENANT=your-tenant                    # e.g., "my-project", "team-a"
TENANT_NAMESPACE=your-tenant          # Memory namespace (usually same as TENANT)
TENANT_PROJECT=YOUR-PROJECT-KEY       # Primary Jira project key (e.g., "PROJ", "MYTEAM")

# Repository paths for tenant-specific workflows
TENANT_DOCS_REPO=project-docs         # Name of docs repo (e.g., "gw-docs", "project-docs")
TENANT_SMOKE_TEST_PATH=lambda-functions/tests/smoke/smoke-test.js  # Path to smoke test script

# =============================================================================
# INTEGRATION PROVIDERS
# =============================================================================
# Define which issue tracker and VCS provider to use
# Skills in base-agents are provider-agnostic; MCPs are being deprecated

ISSUE_TRACKER=jira                    # Options: jira, github, linear
VCS_PROVIDER=bitbucket                # Options: bitbucket, github

# =============================================================================
# AWS BEDROCK CONFIGURATION
# =============================================================================
# Claude Code uses AWS Bedrock for API access
# Set CLAUDE_CODE_USE_BEDROCK=1 in ~/.claude/settings.json

AWS_PROFILE=default
AWS_REGION=us-east-1
CLAUDE_CODE_MAX_OUTPUT_TOKENS=32000

# Enable telemetry for cost tracking
CLAUDE_CODE_ENABLE_TELEMETRY=1

# =============================================================================
# BITBUCKET CONFIGURATION
# =============================================================================
# Required when VCS_PROVIDER=bitbucket

BITBUCKET_USERNAME=YOUR_BITBUCKET_USERNAME
BITBUCKET_TOKEN=YOUR_BITBUCKET_APP_PASSWORD
BITBUCKET_WORKSPACE=your-org
BITBUCKET_DEFAULT_BRANCH=main

# Repository slugs for this tenant (comma-separated)
# Example for tenant A:
#   BITBUCKET_REPOSITORY_SLUGS=api-service,auth-service,frontend-app,sdk,cli-tool,project-docs,bootstrap,test-data
# Example for tenant B:
#   BITBUCKET_REPOSITORY_SLUGS=issue-daemon,slack,jira,bitbucket,agentdb,project-agents,base-agents
BITBUCKET_REPOSITORY_SLUGS=

# =============================================================================
# JIRA CONFIGURATION
# =============================================================================
# Required when ISSUE_TRACKER=jira

JIRA_HOST=your-org.atlassian.net
JIRA_USERNAME=YOUR_JIRA_EMAIL
JIRA_API_TOKEN=YOUR_JIRA_API_TOKEN
JIRA_PROTOCOL=https

# Project keys for this tenant (comma-separated)
# Example for tenant A: PROJ,INTAKE
# Example for tenant B: TEAMB
JIRA_PROJECT_KEYS=

# =============================================================================
# GITHUB CONFIGURATION
# =============================================================================
# Required when ISSUE_TRACKER=github or VCS_PROVIDER=github

GITHUB_TOKEN=YOUR_GITHUB_TOKEN
GITHUB_OWNER=your-org
GITHUB_API_URL=https://api.github.com       # Change for GitHub Enterprise Server

# =============================================================================
# LINEAR CONFIGURATION
# =============================================================================
# Required when ISSUE_TRACKER=linear

LINEAR_API_KEY=YOUR_LINEAR_API_KEY
LINEAR_TEAM_KEY=your-team

# =============================================================================
# CI/CD PROVIDER CONFIGURATION
# =============================================================================

CI_PROVIDER=concourse                       # Options: concourse, github_actions

# =============================================================================
# SLACK CONFIGURATION
# =============================================================================
# Optional: For notifications and alerts

SLACK_BOT_TOKEN=YOUR_SLACK_BOT_TOKEN
SLACK_DEFAULT_CHANNEL=YOUR_SLACK_CHANNEL_ID

# =============================================================================
# AGENTDB CONFIGURATION
# =============================================================================
# AgentDB provides cross-session memory for agents
# Used by hooks for pattern storage and cross-session learning

AGENTDB_API_KEY=YOUR_AGENTDB_API_KEY
AGENTDB_URL=YOUR_AGENTDB_URL

# =============================================================================
# DAEMON CONFIGURATION
# =============================================================================
# Controls agent orchestration behavior

MAX_AGENTS_PER_REPO=2
MAX_AGENTS_TOTAL=6
POLL_INTERVAL_MS=60000
AGENT_TIMEOUT_MS=1800000
HEALTH_CHECK_INTERVAL_MS=30000

# Logging
LOG_LEVEL=info
VERBOSE=false

# Development mode (skip actual execution)
DRY_RUN=false

# =============================================================================
# PROJECT ROOT CONFIGURATION
# =============================================================================
# Used by install.sh and update.sh to locate repositories

# Project root directory (parent of all repos)
# Example: /Users/yourname/projects/my-project
PROJECT_ROOT=

# Comma-separated list of core repositories
# These are synced during update.sh and receive hooks during install.sh
# Example for tenant A: api-service,auth-service,frontend-app,sdk,cli-tool
# Example for tenant B: issue-daemon,jira,bitbucket,slack,agentdb
PROJECT_REPOS=

# Optional repositories (not always present)
PROJECT_REPOS_OPTIONAL=

# =============================================================================
# REPOSITORY CONFIGURATION (JSON)
# =============================================================================
# Detailed configuration for each repository managed by the daemon
# This JSON array defines:
#   - name: Human-readable name
#   - slug: Bitbucket repository slug
#   - workspace: Bitbucket workspace
#   - path: Local filesystem path
#   - maxConcurrentAgents: Max agents working on this repo
#   - jiraProject: Associated Jira project key
#   - branches: Base branch and agent branch prefix

REPOSITORIES='[
  {
    "name": "Example Repository",
    "slug": "example-repo",
    "workspace": "your-org",
    "path": "/path/to/example-repo",
    "maxConcurrentAgents": 2,
    "jiraProject": "EXAMPLE",
    "branches": { "base": "main", "prefix": "agent/" }
  }
]'

