# Install skills (progressive disclosure examples, documentation)
install_skills() {
    log_section "Installing Skills"

    local skills_src="$BASE_AGENTS_ROOT/.claude/skills"
    local skills_dst="${CLAUDE_DIR}/skills"

    if [[ ! -d "$skills_src" ]]; then
        log_warn "Skills directory not found: ${skills_src}"
        return 0
    fi

    mkdir -p "$skills_dst"

    # Copy skill files and directories from base-agents
    cp -r "$skills_src"/* "$skills_dst/" 2>/dev/null || true

    # Apply tenant-specific skill overrides
    local gw_skills="${REPO_DIR}/.claude/skills"
    if [[ -d "$gw_skills" ]]; then
        cp -r "$gw_skills"/* "$skills_dst/" 2>/dev/null || true
        log_info "Applied tenant skill overrides"
    fi

    log_ok "Skills installed"
}

# Generate skills cache for fast session startup
generate_skills_cache() {
    log_section "Generating Skills Cache"

    local cache_builder="${CLAUDE_DIR}/hooks/skills-cache-builder.py"

    if [[ ! -f "$cache_builder" ]]; then
        log_warn "Skills cache builder not found: ${cache_builder}"
        return 1
    fi

    # Run the cache builder
    if python3 "$cache_builder" &>/dev/null; then
        log_ok "Skills cache generated successfully"
    else
        log_warn "Failed to generate skills cache (non-fatal)"
    fi
}

# Create symlinks from project root to global skills (REST executable skills)
# This enables project-relative paths like .claude/skills/jira/search_issues.ts
symlink_skills_to_project() {
    log_section "Creating Skills Symlinks in Project Root"

    # Load configuration
    if [[ -f "$ENV_FILE" ]]; then
        source "$ENV_FILE"
    fi

    # Resolve project root
    local project_root="${PROJECT_ROOT:-$(dirname "$REPO_DIR")}"
    if [[ "$project_root" == ".." || "$project_root" == "../"* ]]; then
        project_root="$(cd "$REPO_DIR" && cd "$project_root" && pwd)"
    fi

    local project_skills="${project_root}/.claude/skills"
    local global_skills="${CLAUDE_DIR}/skills"

    # REST skill directories to symlink
    local skill_dirs=("jira" "bitbucket" "agentdb" "slack" "cml" "concourse" "fly" "playwright")

    # Create project .claude/skills directory if needed
    mkdir -p "$project_skills"

    local linked=0
    local skipped=0

    for skill_dir in "${skill_dirs[@]}"; do
        local src="${global_skills}/${skill_dir}"
        local dst="${project_skills}/${skill_dir}"

        if [[ ! -d "$src" ]]; then
            log_warn "${skill_dir}: source not found at ${src}"
            continue
        fi

        if [[ -L "$dst" ]]; then
            # Already a symlink - check if it points to the right place
            local current_target=$(readlink "$dst")
            if [[ "$current_target" == "$src" ]]; then
                log_ok "${skill_dir}: symlink already exists"
                ((skipped++))
            else
                # Symlink exists but points elsewhere - update it
                rm "$dst"
                ln -s "$src" "$dst"
                log_ok "${skill_dir}: symlink updated"
                ((linked++))
            fi
        elif [[ -d "$dst" ]]; then
            # Directory exists (not a symlink) - warn and skip
            log_warn "${skill_dir}: directory exists at ${dst} (not a symlink, skipping)"
            ((skipped++))
        else
            # Create new symlink
            ln -s "$src" "$dst"
            log_ok "${skill_dir}: symlink created"
            ((linked++))
        fi
    done

    log_ok "Skills symlinks: ${linked} created, ${skipped} skipped"
    log_info "Project-relative paths now work: .claude/skills/jira/search_issues.ts"
}

# Setup project-root .claude/ directory with config templates and rx files
# Seeds credentials.json, settings.json, repositories.json if missing;
# always syncs rx command and skill, and copies commands to project root.
setup_project_claude_dir() {
    log_section "Setting Up Project Root .claude/ Directory"

    # Load configuration
    if [[ -f "$ENV_FILE" ]]; then
        source "$ENV_FILE"
    fi

    # Resolve project root
    local project_root="${PROJECT_ROOT:-$(dirname "$REPO_DIR")}"
    if [[ "$project_root" == ".." || "$project_root" == "../"* ]]; then
        project_root="$(cd "$REPO_DIR" && cd "$project_root" && pwd)"
    fi

    local project_claude="${project_root}/.claude"
    mkdir -p "${project_claude}/commands" "${project_claude}/skills"

    # --- Seed credentials.json (only if missing) ---
    local creds_file="${project_claude}/credentials.json"
    local creds_template="${REPO_DIR}/templates/project-credentials.json"
    if [[ ! -f "$creds_file" ]]; then
        if [[ -f "$creds_template" ]]; then
            cp "$creds_template" "$creds_file"
            log_ok "credentials.json: seeded template (fill in your values)"
        else
            log_warn "credentials.json template not found: ${creds_template}"
        fi
    else
        log_ok "credentials.json: already exists"
    fi

    # --- Seed settings.json (only if missing) ---
    local settings_file="${project_claude}/settings.json"
    local settings_template="${REPO_DIR}/templates/project-settings.json"
    if [[ ! -f "$settings_file" ]]; then
        if [[ -f "$settings_template" ]]; then
            cp "$settings_template" "$settings_file"
            log_ok "settings.json: seeded template"
        else
            log_warn "settings.json template not found: ${settings_template}"
        fi
    else
        log_ok "settings.json: already exists"
    fi

    # --- Copy repositories.json (always update) ---
    local repos_src="${REPO_DIR}/config/repositories.json"
    local repos_dst="${project_claude}/repositories.json"
    if [[ -f "$repos_src" ]]; then
        cp "$repos_src" "$repos_dst"
        log_ok "repositories.json: updated from config"
    else
        log_warn "repositories.json source not found: ${repos_src}"
    fi

    # --- Sync rx command to project root ---
    local rx_cmd_src="${REPO_DIR}/.claude/commands/rx.md"
    local rx_cmd_dst="${project_claude}/commands/rx.md"
    if [[ -f "$rx_cmd_src" ]]; then
        cp "$rx_cmd_src" "$rx_cmd_dst"
        log_ok "commands/rx.md: installed"
    fi

    # --- Sync rx skill to project root ---
    local rx_skill_src="${REPO_DIR}/.claude/skills/rx"
    local rx_skill_dst="${project_claude}/skills/rx"
    if [[ -d "$rx_skill_src" ]]; then
        # Copy entire rx directory (it's a TypeScript package, not a symlink target)
        mkdir -p "$rx_skill_dst"
        cp -r "$rx_skill_src"/* "$rx_skill_dst/" 2>/dev/null || true
        log_ok "skills/rx: installed"
    fi

    log_ok "Project root .claude/ directory configured"
}

# Install workflows
install_workflows() {
    log_section "Installing Workflows"

    local workflows_src="${REPO_DIR}/.claude/workflows"
    local workflows_dst="${CLAUDE_DIR}/workflows"

    if [[ ! -d "$workflows_src" ]]; then
        log_warn "Workflows directory not found: ${workflows_src}"
        return 0
    fi

    mkdir -p "$workflows_dst"

    local workflow_count=0

    # Copy workflow YAML files
    for workflow_file in "${workflows_src}"/*.yaml "${workflows_src}"/*.yml; do
        if [[ -f "$workflow_file" ]]; then
            local filename=$(basename "$workflow_file")
            cp "$workflow_file" "${workflows_dst}/${filename}"
            log_ok "Installed workflow: ${filename%.yaml}"
            ((workflow_count++))
        fi
    done

    # Copy README if exists
    if [[ -f "${workflows_src}/README.md" ]]; then
        cp "${workflows_src}/README.md" "${workflows_dst}/README.md"
        log_ok "Installed workflows README"
    fi

    log_ok "Workflows installed: ${workflow_count} workflows"
}

# Install plugins by adding them to settings.json (non-interactive)
# This replaces `claude plugins install` which launches interactive sessions
install_plugins() {
    log_section "Configuring Plugins"

    local settings_file="${CLAUDE_DIR}/settings.json"

    if [[ ! -f "$settings_file" ]]; then
        log_warn "Settings file not found: ${settings_file}"
        return 1
    fi

    # Load plugin list from config/plugins.json (single source of truth)
    local plugins_config="${REPO_DIR}/config/plugins.json"
    local plugins=()

    if [[ -f "$plugins_config" ]] && command -v jq &>/dev/null; then
        while IFS= read -r plugin_id; do
            plugins+=("$plugin_id")
        done < <(jq -r '.[] | "\(.name)@\(.marketplace)"' "$plugins_config")
        log_info "Loaded ${#plugins[@]} plugins from config/plugins.json"
    else
        # Fallback: hardcoded list if config file or jq unavailable
        plugins=(
            "superpowers@claude-plugins-official"
            "context7@claude-plugins-official"
            "code-review@claude-plugins-official"
            "impeccable@impeccable"
            "ralph-loop@claude-plugins-official"
            "ralph-wiggum@claude-plugins-official"
            "concourse-ci@netresearch-claude-code-marketplace"
            "gopls-lsp@claude-plugins-official"
            "typescript-lsp@claude-plugins-official"
        )
        log_warn "Using fallback plugin list (config/plugins.json not found or jq unavailable)"
    fi

    # Ensure enabledPlugins object exists
    local temp_file
    temp_file=$(mktemp)
    jq '.enabledPlugins //= {}' "$settings_file" > "$temp_file"
    mv "$temp_file" "$settings_file"

    for plugin in "${plugins[@]}"; do
        if jq -e ".enabledPlugins[\"${plugin}\"]" "$settings_file" &>/dev/null; then
            log_ok "${plugin}: already enabled"
        else
            temp_file=$(mktemp)
            jq --arg p "$plugin" '.enabledPlugins[$p] = true' "$settings_file" > "$temp_file"
            if jq empty "$temp_file" 2>/dev/null; then
                mv "$temp_file" "$settings_file"
                log_ok "${plugin}: enabled"
            else
                log_error "Failed to enable ${plugin} (invalid JSON)"
                rm -f "$temp_file"
            fi
        fi
    done

    log_ok "Plugins configured"
}

# Install testing tools (Pact)
install_testing_tools() {
    log_section "Installing Testing Tools"

    # Install Pact CLI for contract testing
    log_info "Installing Pact CLI for contract testing..."
    if has_command pact; then
        log_ok "Pact CLI already installed"
    else
        if npm install -g @pact-foundation/pact-cli 2>/dev/null; then
            log_ok "Pact CLI installed"
        else
            log_warn "Could not install Pact CLI globally (may need sudo)"
            log_info "Install manually: npm install -g @pact-foundation/pact-cli"
        fi
    fi

    log_ok "Testing tools installation complete"
}

# Setup supergateway - shared MCP server instances across Claude sessions
setup_supergateway() {
    log_section "Setting Up Supergateway (Shared MCP Servers)"

    local sg_src="${REPO_DIR}/supergateway"
    local sg_dst="${CLAUDE_DIR}/supergateway"

    if [[ ! -d "$sg_src" ]]; then
        log_warn "Supergateway source not found: ${sg_src}"
        return 0
    fi

    # Ensure supergateway npm package is available
    log_info "Verifying supergateway package..."
    if ! npx -y supergateway --version &>/dev/null; then
        log_warn "supergateway not available via npx"
        log_info "  It will be fetched on first run"
    else
        log_ok "supergateway available"
    fi

    # Create runtime directories
    mkdir -p "${sg_dst}/pids" "${sg_dst}/logs"

    # Copy config and scripts
    cp "${sg_src}/config.json" "${sg_dst}/config.json"
    for script in start.sh stop.sh status.sh; do
        cp "${sg_src}/${script}" "${sg_dst}/${script}"
        chmod +x "${sg_dst}/${script}"
    done

    log_ok "Supergateway scripts installed to ${sg_dst}"

    # Install launchd plist for auto-start (macOS only)
    if [[ "$(uname)" == "Darwin" ]]; then
        local plist_name="com.gw.supergateway"
        local plist_dst="${HOME}/Library/LaunchAgents/${plist_name}.plist"
        local plist_src="${sg_src}/${plist_name}.plist"

        if [[ -f "$plist_src" ]]; then
            # Unload existing plist if loaded
            launchctl bootout "gui/$(id -u)/${plist_name}" 2>/dev/null || true

            # Generate plist with resolved paths
            local current_path
            current_path=$(echo "$PATH")
            sed -e "s|__SUPERGATEWAY_DIR__|${sg_dst}|g" \
                -e "s|__LOG_DIR__|${sg_dst}/logs|g" \
                -e "s|__PATH__|${current_path}|g" \
                "$plist_src" > "$plist_dst"

            # Load the plist
            launchctl bootstrap "gui/$(id -u)" "$plist_dst" 2>/dev/null || \
                launchctl load "$plist_dst" 2>/dev/null || \
                log_warn "Could not load launchd plist (may need manual load)"

            log_ok "Launchd agent installed: ${plist_name}"
            log_info "Supergateway will auto-start on login"
        fi
    fi

    # Start the gateways now
    log_info "Starting supergateway instances..."
    if "${sg_dst}/start.sh"; then
        log_ok "Supergateway instances running"
    else
        log_warn "Some supergateway instances failed to start"
        log_info "  Check logs: ${sg_dst}/logs/"
        log_info "  Manual start: ${sg_dst}/start.sh"
    fi

    # Update MCP configurations to use SSE transport
    _update_mcp_for_supergateway

    log_ok "Supergateway setup complete"
}

# Update MCP server configurations to use SSE transport via supergateway
_update_mcp_for_supergateway() {
    local settings_file="${CLAUDE_DIR}/settings.json"
    local claude_json="${HOME}/.claude.json"
    local sg_config="${CLAUDE_DIR}/supergateway/config.json"

    if [[ ! -f "$sg_config" ]]; then
        log_warn "Supergateway config not found, skipping MCP reconfiguration"
        return 0
    fi

    if ! command -v jq &>/dev/null; then
        log_warn "jq not found, skipping MCP reconfiguration"
        return 0
    fi

    # Read server configs
    local server_names
    server_names=$(jq -r '.servers | keys[]' "$sg_config")

    for name in $server_names; do
        local port scope
        port=$(jq -r ".servers[\"${name}\"].port" "$sg_config")
        scope=$(jq -r ".servers[\"${name}\"].scope" "$sg_config")
        local sse_url="http://localhost:${port}/sse"

        if [[ "$scope" == "user" ]]; then
            # Update user-level MCP in ~/.claude.json
            if [[ -f "$claude_json" ]]; then
                local temp_file
                temp_file=$(mktemp)

                # Check if server exists in top-level mcpServers
                if jq -e ".mcpServers[\"${name}\"]" "$claude_json" &>/dev/null; then
                    # Replace stdio config with SSE
                    jq ".mcpServers[\"${name}\"] = {\"type\": \"sse\", \"url\": \"${sse_url}\"}" \
                        "$claude_json" > "$temp_file"

                    if jq empty "$temp_file" 2>/dev/null; then
                        mv "$temp_file" "$claude_json"
                        log_ok "${name}: updated to SSE in ~/.claude.json (${sse_url})"
                    else
                        log_error "${name}: generated invalid JSON, skipping"
                        rm -f "$temp_file"
                    fi
                else
                    # Add new SSE entry
                    jq ".mcpServers[\"${name}\"] = {\"type\": \"sse\", \"url\": \"${sse_url}\"}" \
                        "$claude_json" > "$temp_file"

                    if jq empty "$temp_file" 2>/dev/null; then
                        mv "$temp_file" "$claude_json"
                        log_ok "${name}: added as SSE to ~/.claude.json (${sse_url})"
                    else
                        rm -f "$temp_file"
                    fi
                fi
            fi
        else
            # Project-scope servers: add to global settings.json mcpServers
            if [[ -f "$settings_file" ]]; then
                local temp_file
                temp_file=$(mktemp)

                jq ".mcpServers[\"${name}\"] = {\"type\": \"sse\", \"url\": \"${sse_url}\"}" \
                    "$settings_file" > "$temp_file"

                if jq empty "$temp_file" 2>/dev/null; then
                    mv "$temp_file" "$settings_file"
                    log_ok "${name}: added as SSE to settings.json (${sse_url})"
                else
                    rm -f "$temp_file"
                fi
            fi
        fi
    done

    # Configure per-session stdio MCP servers (not shared via supergateway)
    # Prefer stdio over supergateway SSE: stdio gives each session its own
    # process, avoids the supergateway SSE reconnection crash bug, and
    # eliminates shared-state conflicts between concurrent sessions.
    if [[ -f "$claude_json" ]]; then
        local temp_file
        temp_file=$(mktemp)

        jq '
            del(.mcpServers["chrome-devtools"]) |
            .mcpServers["CodeGraphContext"] = {"command": "cgc", "args": ["mcp", "start"], "type": "stdio"}
        ' "$claude_json" > "$temp_file"

        if jq empty "$temp_file" 2>/dev/null; then
            mv "$temp_file" "$claude_json"
            log_ok "chrome-devtools: removed from ~/.claude.json (replaced by Playwright)"
            log_ok "CodeGraphContext: configured as stdio in ~/.claude.json"
        else
            log_error "stdio MCP servers: generated invalid JSON, skipping"
            rm -f "$temp_file"
        fi
    fi
}

# Install tokf filters for fly and terraform commands
setup_tokf() {
    log_section "Setting Up Tokf Filters"

    if ! has_command tokf; then
        log_warn "tokf not installed - skipping filter setup"
        log_info "  Install via: brew install mpecan/tokf/tokf"
        return 0
    fi

    log_ok "tokf installed ($(tokf --version 2>/dev/null || echo 'unknown'))"

    local tokf_src="${REPO_DIR}/tokf/filters"

    if [[ ! -d "$tokf_src" ]]; then
        log_warn "Tokf filter source not found: ${tokf_src}"
        return 0
    fi

    # Determine user-level filter directory (macOS vs Linux)
    local tokf_dst
    if [[ "$(uname)" == "Darwin" ]]; then
        tokf_dst="${HOME}/Library/Application Support/tokf/filters"
    else
        tokf_dst="${HOME}/.config/tokf/filters"
    fi

    # Copy filter directories preserving structure
    local filter_count=0
    while IFS= read -r -d '' filter_file; do
        local rel_path="${filter_file#"${tokf_src}/"}"
        local dest_dir
        dest_dir="$(dirname "${tokf_dst}/${rel_path}")"
        mkdir -p "$dest_dir"
        cp "$filter_file" "${tokf_dst}/${rel_path}"
        filter_count=$((filter_count + 1))
    done < <(find "$tokf_src" -name '*.toml' -print0)

    if [[ $filter_count -gt 0 ]]; then
        log_ok "Installed ${filter_count} tokf filters to ${tokf_dst}"
    else
        log_warn "No .toml filter files found in ${tokf_src}"
    fi

    log_ok "Tokf filter setup complete"
}

install_playwright() {
    log_section "Installing Playwright"

    if ! has_command npx; then
        log_warn "npx not available - skipping Playwright install"
        log_info "  Install Node.js first, then re-run install.sh"
        return 0
    fi

    # Install Chromium browser binary
    if npx playwright install chromium 2>/dev/null; then
        log_ok "Chromium browser installed"
    else
        log_warn "Failed to install Chromium browser"
        log_info "  Run manually: npx playwright install chromium"
    fi
}

# Install and configure CodeGraphContext (code graph MCP server)
setup_codegraphcontext() {
    log_section "Setting Up CodeGraphContext"

    # Check Python 3.10+ is available
    if ! has_command python3; then
        log_warn "python3 not found - skipping CodeGraphContext installation"
        log_info "  Install Python 3.10+ to enable code graph analysis"
        return 0
    fi

    local python_version
    python_version=$(python3 -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")' 2>/dev/null)
    local python_major python_minor
    python_major=$(echo "$python_version" | cut -d. -f1)
    python_minor=$(echo "$python_version" | cut -d. -f2)

    if [[ "$python_major" -lt 3 ]] || { [[ "$python_major" -eq 3 ]] && [[ "$python_minor" -lt 10 ]]; }; then
        log_warn "Python ${python_version} found, but 3.10+ required for CodeGraphContext"
        return 0
    fi

    log_ok "Python ${python_version} available"

    # Install codegraphcontext via pip
    if has_command cgc; then
        local cgc_version
        cgc_version=$(cgc --version 2>&1 | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' || echo "unknown")
        log_ok "CodeGraphContext already installed (${cgc_version})"
    else
        log_info "Installing CodeGraphContext via pip..."
        if pip3 install codegraphcontext 2>/dev/null; then
            log_ok "CodeGraphContext installed"
        else
            log_warn "Could not install CodeGraphContext"
            log_info "  Install manually: pip3 install codegraphcontext"
            return 0
        fi
    fi

    # Fix FalkorDB binary on macOS ARM64 (ships with Linux ELF binary)
    if [[ "$(uname)" == "Darwin" ]] && [[ "$(uname -m)" == "arm64" ]]; then
        local falkordb_so
        falkordb_so=$(python3 -c "
import importlib.util
spec = importlib.util.find_spec('redislite')
if spec and spec.submodule_search_locations:
    import os
    print(os.path.join(spec.submodule_search_locations[0], 'bin', 'falkordb.so'))
" 2>/dev/null)

        if [[ -n "$falkordb_so" ]] && [[ -f "$falkordb_so" ]]; then
            local file_type
            file_type=$(file "$falkordb_so" 2>/dev/null)
            if echo "$file_type" | grep -q "ELF"; then
                log_info "Replacing Linux FalkorDB binary with macOS ARM64 version..."
                local falkordb_version
                falkordb_version=$(python3 -c "
try:
    from importlib.metadata import metadata
    m = metadata('falkordblite')
    # Extract version from setup.py constant
    print('v4.16.2')
except Exception:
    print('v4.16.2')
" 2>/dev/null)
                local download_url="https://github.com/FalkorDB/FalkorDB/releases/download/${falkordb_version}/falkordb-macos-arm64v8.so"
                if curl -L -o "${falkordb_so}" "$download_url" 2>/dev/null; then
                    log_ok "FalkorDB macOS ARM64 binary installed"
                else
                    log_warn "Could not download FalkorDB macOS binary"
                    log_info "  CodeGraphContext may fall back to Neo4j backend"
                fi
            else
                log_ok "FalkorDB binary is already macOS-compatible"
            fi
        fi
    fi

    # Configure MCP server for Claude Code (user scope)
    if has_command claude; then
        # Check if already configured
        local claude_json="$HOME/.claude.json"
        if [[ -f "$claude_json" ]] && grep -q '"CodeGraphContext"' "$claude_json" 2>/dev/null; then
            log_ok "CodeGraphContext MCP server already configured"
        else
            log_info "Adding CodeGraphContext MCP server to Claude Code..."
            if claude mcp add -s user CodeGraphContext -- cgc mcp start 2>/dev/null; then
                log_ok "CodeGraphContext MCP server configured (user scope)"
            else
                log_warn "Could not configure MCP server automatically"
                log_info "  Add manually: claude mcp add -s user CodeGraphContext -- cgc mcp start"
            fi
        fi
    fi

    log_ok "CodeGraphContext setup complete"
}

# Setup agentdb (remote memory service)
setup_agentdb_mcp() {
    log_section "Setting Up AgentDB MCP (Remote Memory)"

    local settings_file="${CLAUDE_DIR}/settings.json"
    local agentdb_url="YOUR_AGENTDB_URL/sse"

    # Check if already configured
    if grep -q '"agentdb"' "$settings_file" 2>/dev/null; then
        log_ok "agentdb: already configured in settings"
        return 0
    fi

    echo ""
    log_info "AgentDB MCP provides persistent memory across Claude sessions."
    log_info "Service URL: ${agentdb_url}"
    echo ""

    # Try to get API key from AWS Secrets Manager
    local api_key=""
    if has_command aws; then
        log_info "Attempting to retrieve API key from AWS Secrets Manager..."
        api_key=$(aws secretsmanager get-secret-value \
            --secret-id agentdb-dev-api-key \
            --region us-east-1 \
            --query 'SecretString' \
            --output text 2>/dev/null | jq -r '.apiKey' 2>/dev/null || echo "")
    fi

    if [[ -z "$api_key" ]]; then
        log_warn "Could not retrieve API key automatically."
        log_info "You need the 'agentdb-dev-read-api-key' IAM policy attached to your user."
        log_info "Or get the key manually: ./scripts/get-api-key.sh (in agentdb repo)"
        echo ""
        read -sp "Enter AgentDB API Key (or press Enter to skip): " input_api_key
        echo ""
        api_key="$input_api_key"
    fi

    if [[ -z "$api_key" ]]; then
        log_warn "Skipping agentdb configuration (no API key)"
        log_info "To add later, run: ./scripts/install.sh --configure-agentdb"
        return 0
    fi

    # Add to settings.json using jq
    if has_command jq; then
        local temp_file=$(mktemp)
        jq --arg url "$agentdb_url" --arg key "$api_key" \
            '.mcpServers["agentdb"] = {
                "url": $url,
                "transport": "sse",
                "headers": { "X-Api-Key": $key }
            }' "$settings_file" > "$temp_file"
        mv "$temp_file" "$settings_file"
        log_ok "agentdb configured in settings.json"
    else
        log_warn "jq not found - please add agentdb manually to ${settings_file}"
        log_info "Configuration:"
        cat <<EOF
    "agentdb": {
      "url": "${agentdb_url}",
      "transport": "sse",
      "headers": {
        "X-Api-Key": "${api_key}"
      }
    }
EOF
    fi
}

# configure_settings() REMOVED
# Settings are now fully managed by install_global_hook_config() using
# base/.claude/settings.template.json as the single source of truth.
# The old templates/settings.json.template was a stale duplicate.
configure_settings() {
    log_info "Note: Settings managed by install_global_hook_config()"
}

# Copy CLAUDE.md template to user's home for reference
setup_claude_md() {
    log_section "Setting Up Global CLAUDE.md"

    local template="${REPO_DIR}/CLAUDE.md.template"
    local target="${CLAUDE_DIR}/CLAUDE.md"

    if [[ -f "$target" ]]; then
        log_warn "Global CLAUDE.md already exists"
        read -p "Append project-agents instructions? (y/N): " confirm
        if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
            echo "" >> "$target"
            echo "# Project Agents Integration" >> "$target"
            echo "$(cat "$template")" >> "$target"
            log_ok "Project Agents instructions appended"
        fi
    else
        cp "$template" "$target"
        log_ok "Global CLAUDE.md created"
    fi
}

# Install parent CLAUDE.md to project root
setup_parent_claude_md() {
    log_section "Setting Up Parent CLAUDE.md"

    # Load configuration
    if [[ -f "$ENV_FILE" ]]; then
        source "$ENV_FILE"
    fi

    # Resolve project root
    local project_root="${PROJECT_ROOT:-$(dirname "$REPO_DIR")}"
    if [[ "$project_root" == ".." || "$project_root" == "../"* ]]; then
        project_root="$(cd "$REPO_DIR" && cd "$project_root" && pwd)"
    fi

    local template="${REPO_DIR}/templates/parent-CLAUDE.md"
    local target="${project_root}/CLAUDE.md"

    if [[ ! -f "$template" ]]; then
        log_warn "Parent CLAUDE.md template not found: ${template}"
        return 1
    fi

    if [[ -f "$target" ]]; then
        # Check if it's managed by project-agents (has our footer)
        if grep -q "Managed by project-agents" "$target" 2>/dev/null; then
            log_info "Updating existing parent CLAUDE.md..."
            cp "$target" "${target}.backup.$(date +%Y%m%d_%H%M%S)"
            cp "$template" "$target"
            log_ok "Parent CLAUDE.md updated at ${target}"
        else
            log_warn "Parent CLAUDE.md exists but is not managed by project-agents"
            read -p "Replace with project-agents template? Existing will be backed up. (y/N): " confirm
            if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
                cp "$target" "${target}.backup.$(date +%Y%m%d_%H%M%S)"
                cp "$template" "$target"
                log_ok "Parent CLAUDE.md replaced at ${target}"
                log_info "Backup saved with .backup.* extension"
            else
                log_info "Keeping existing parent CLAUDE.md"
            fi
        fi
    else
        cp "$template" "$target"
        log_ok "Parent CLAUDE.md created at ${target}"
    fi
}

# Show status of current setup
show_status() {
    log_section "Current Setup Status"

    # Check Claude CLI
    if has_command claude; then
        log_ok "Claude Code CLI: installed"
    else
        log_warn "Claude Code CLI: not installed"
    fi

    # Check MCP servers
    echo ""
    log_info "MCP Servers:"
    if claude mcp list &>/dev/null; then
        claude mcp list
    else
        log_warn "Could not list MCP servers"
    fi

    # Check commands
    echo ""
    log_info "Installed Commands:"
    local cmd_count=0
    for cmd in "${CLAUDE_DIR}/commands"/*.md; do
        if [[ -f "$cmd" ]]; then
            echo "  - $(basename "${cmd%.md}")"
            ((cmd_count++))
        fi
    done
    log_info "Total: ${cmd_count} commands"

    # Check hooks
    echo ""
    log_info "Installed Hooks:"
    local hook_count=0
    for hook in "${CLAUDE_DIR}/hooks"/*.py "${CLAUDE_DIR}/hooks"/*.sh; do
        if [[ -f "$hook" ]]; then
            echo "  - $(basename "$hook")"
            ((hook_count++))
        fi
    done
    log_info "Total: ${hook_count} hooks"

    # Check .env
    echo ""
    if [[ -f "$ENV_FILE" ]]; then
        log_ok "Credentials file: ${ENV_FILE}"
    else
        log_warn "Credentials file: not found (run install.sh to configure)"
    fi
}

# Uninstall
uninstall() {
    log_section "Uninstalling Project Agents Configuration"

    read -p "This will remove project workflow commands and hooks. Continue? (y/N): " confirm
    if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
        log_info "Aborted"
        exit 0
    fi

    # Remove commands
    for cmd in plan groom work validate audit next bug issue fix-pipeline; do
        rm -f "${CLAUDE_DIR}/commands/${cmd}.md"
    done
    log_ok "Commands removed"

    # Remove hooks
    rm -f "${CLAUDE_DIR}/hooks/workflow-pattern-trainer.py"
    log_ok "Hooks removed"

    # Remove MCP servers
    for mcp in jira bitbucket; do
        claude mcp remove "$mcp" 2>/dev/null || true
    done
    log_ok "Project MCP servers removed (core servers retained)"

    log_ok "Uninstall complete"
}

# Show usage
usage() {
    cat <<EOF
Project Agents - Developer Setup Script

Usage:
  ${0##*/}                    Interactive setup
  ${0##*/} --check            Check current setup status
  ${0##*/} --update-commands  Update workflow commands only
  ${0##*/} --configure-repos  Configure and clone project repositories
  ${0##*/} --configure-agentdb Configure agentdb only
  ${0##*/} --configure-supergateway Configure supergateway only
  ${0##*/} --uninstall        Remove project configuration

Options:
  --check              Show current setup status
  --validate           Validate current installation integrity
  --update-commands    Update workflow commands only
  --configure-repos    Configure project repositories (PROJECT_REPOS in .env)
                       and clone any missing repositories
  --configure-agentdb  Configure agentdb remote memory service
  --configure-supergateway  Configure supergateway shared MCP servers
  --uninstall          Remove tenant-specific configuration
  --help               Show this help message

Multi-Repo Setup:
  The install script can clone all project repositories for new developers.
  Configure PROJECT_REPOS in .env or use --configure-repos to set up interactively.

  Default repositories:
    api, spa, auth, sdk, docs, test-data, e2e, evals, migrations

Documentation:
  README.md          Overview and quick start
  docs/MCP-SETUP.md  Detailed MCP server setup

EOF
    exit 0
}

# Update commands only
update_commands() {
    log_section "Updating Workflow Commands"
    install_commands
    install_hooks
    install_statusline
    install_global_hook_config
    setup_project_hooks
    install_skills
    generate_skills_cache
    symlink_skills_to_project
    setup_project_claude_dir
    install_workflows
    log_ok "Commands, hooks, skills, and workflows updated"
}

# Configure agentdb only
configure_agentdb_only() {
    log_section "Configuring AgentDB MCP"
    setup_agentdb_mcp
    log_ok "AgentDB MCP configuration complete"
}

# Configure supergateway only
configure_supergateway_only() {
    log_section "Configuring Supergateway"
    setup_supergateway
    log_ok "Supergateway configuration complete"
}

# Configure and clone project repos only
configure_repos_only() {
    log_section "Configuring Project Repositories"
    configure_project_repos
    setup_project_repos
    log_ok "Project repository configuration complete"
}

# Update tool permissions in settings.json
update_tool_permissions() {
    log_section "Updating Tool Permissions"

    local permissions_script="${REPO_DIR}/scripts/update-permissions.sh"

    if [[ -x "$permissions_script" ]]; then
        "$permissions_script" --claude-dir "$CLAUDE_DIR"
    else
        log_warn "Permissions script not found or not executable: ${permissions_script}"
        log_info "Skipping automatic permission updates"
    fi
}

# Validate installation integrity
validate_installation() {
    log_section "Validating Installation"

    local errors=0

    # 1. Validate settings.json is valid JSON
    local settings_file="${CLAUDE_DIR}/settings.json"
    if [[ -f "$settings_file" ]]; then
        if jq empty "$settings_file" 2>/dev/null; then
            log_ok "settings.json: valid JSON"
        else
            log_error "settings.json: INVALID JSON"
            errors=$((errors + 1))
        fi
    else
        log_error "settings.json: not found"
        errors=$((errors + 1))
    fi

    # 2. Verify hook scripts exist
    local hook_scripts=(
        "session-start-workflow-prompt.py"
        "result-compressor.py"
        "post-command.py"
        "workflow-pattern-trainer.py"
        "memory-optimizer.sh"
        "enforce-worktree.sh"
        "checkpoint-loader.py"
    )
    local hook_dir="${CLAUDE_DIR}/hooks"
    for hook in "${hook_scripts[@]}"; do
        if [[ -f "${hook_dir}/${hook}" ]]; then
            log_ok "hook ${hook}: present"
        else
            log_warn "hook ${hook}: missing"
        fi
    done

    # 3. Verify required commands
    local cmd_dir="${CLAUDE_DIR}/commands"
    local required_commands=("work" "validate" "next" "implement" "review" "fix-pr" "resolve-pr")
    for cmd in "${required_commands[@]}"; do
        if [[ -f "${cmd_dir}/${cmd}.md" ]]; then
            log_ok "command /${cmd}: installed"
        else
            log_warn "command /${cmd}: missing"
        fi
    done

    # 4. Verify plugins configured
    if [[ -f "$settings_file" ]]; then
        local plugin_count
        plugin_count=$(jq '.enabledPlugins // {} | length' "$settings_file" 2>/dev/null || echo "0")
        if [[ "$plugin_count" -gt 0 ]]; then
            log_ok "Plugins configured: ${plugin_count}"
        else
            log_warn "No plugins configured"
        fi
    fi

    # 5. Verify brew packages
    if command -v jq &>/dev/null; then
        load_brew_packages "$BASE_CONFIG_DIR" "$TENANT_CONFIG_DIR"
        local pkg_count
        pkg_count=$(echo "$BREW_PACKAGES" | jq 'length')
        local i=0
        while [[ $i -lt $pkg_count ]]; do
            local name required
            name=$(echo "$BREW_PACKAGES" | jq -r ".[$i].name")
            required=$(echo "$BREW_PACKAGES" | jq -r ".[$i].required")
            local cmd_name="${name##*/}"
            if command -v "$cmd_name" &>/dev/null || brew list --formula "$name" &>/dev/null 2>&1; then
                log_ok "brew ${name}: installed"
            elif [[ "$required" == "true" ]]; then
                log_error "brew ${name}: MISSING (required)"
                errors=$((errors + 1))
            else
                log_warn "brew ${name}: not installed (optional)"
            fi
            i=$((i + 1))
        done
    fi

    # 6. Verify statusline
    if [[ -f "${CLAUDE_DIR}/statusline-command.sh" ]]; then
        log_ok "statusline: installed"
    else
        log_warn "statusline: missing"
    fi

    # 7. Verify skill symlinks
    local project_root="${PROJECT_ROOT:-$(dirname "$REPO_DIR")}"
    if [[ "$project_root" == ".." || "$project_root" == "../"* ]]; then
        project_root="$(cd "$REPO_DIR" && cd "$project_root" && pwd)"
    fi
    local skill_dirs=("jira" "bitbucket" "agentdb" "slack" "playwright")
    for skill in "${skill_dirs[@]}"; do
        if [[ -L "${project_root}/.claude/skills/${skill}" ]] || [[ -d "${project_root}/.claude/skills/${skill}" ]]; then
            log_ok "skill symlink ${skill}: present"
        else
            log_warn "skill symlink ${skill}: missing"
        fi
    done

    # 8. Verify extraKnownMarketplaces includes impeccable
    if [[ -f "$settings_file" ]]; then
        if jq -e '.extraKnownMarketplaces.impeccable' "$settings_file" &>/dev/null; then
            log_ok "impeccable marketplace: configured"
        else
            log_warn "impeccable marketplace: not configured"
        fi
    fi

    echo ""
    if [[ $errors -gt 0 ]]; then
        log_error "Validation found ${errors} error(s)"
        return 1
    else
        log_ok "Validation passed"
        return 0
    fi
}

# Main installation
main() {
    echo ""
    echo -e "${CYAN}╔═══════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║   Project Agents - Claude Code Setup Script    ║${NC}"
    echo -e "${CYAN}╚═══════════════════════════════════════════╝${NC}"
    echo ""

    check_prerequisites
    install_claude_cli
    init_base_agents_submodule
    install_brew_packages
    setup_claude_directory
    install_core_mcp_servers
    # setup_mcp_repos  # DEPRECATED: Skills now call REST APIs directly
    setup_project_repos
    setup_gw_docs
    # setup_project_mcp_servers  # DEPRECATED: Skills now call REST APIs directly
    install_commands
    install_hooks
    install_statusline
    install_global_hook_config
    setup_project_hooks
    install_skills
    generate_skills_cache
    symlink_skills_to_project
    setup_project_claude_dir
    install_workflows
    install_plugins
    install_testing_tools
    setup_codegraphcontext
    setup_supergateway
    setup_tokf
    install_playwright
    configure_settings
    setup_agentdb_mcp
    setup_claude_md
    setup_parent_claude_md
    update_tool_permissions
    validate_installation

    # --- Post-Install Verification (rx) ---
    log_section "Post-Install Verification"
    log_info "Running rx to verify installation..."

    RX_SCRIPT="${CLAUDE_DIR}/skills/rx/rx.ts"
    if [[ -f "$RX_SCRIPT" ]]; then
      RX_OUTPUT=$(npx tsx "$RX_SCRIPT" --json 2>/dev/null || true)

      if [[ -n "$RX_OUTPUT" ]]; then
        TOTAL=$(echo "$RX_OUTPUT" | jq -r '.summary.total // 0')
        PASS=$(echo "$RX_OUTPUT" | jq -r '.summary.pass // 0')
        FIXED=$(echo "$RX_OUTPUT" | jq -r '.summary.fixed // 0')
        FAIL=$(echo "$RX_OUTPUT" | jq -r '.summary.fail // 0')

        if [[ "$FAIL" -eq 0 ]]; then
          log_ok "All ${TOTAL} checks passed (${PASS} pass, ${FIXED} fixed)"
        else
          log_warn "${FAIL} checks failed out of ${TOTAL}. Run ./scripts/rx.sh for details."
        fi
      else
        log_warn "rx verification returned empty output. Run ./scripts/rx.sh manually."
      fi
    else
      log_info "rx skill not yet installed. Run ./scripts/rx.sh after installation to verify."
    fi

    # Cleanup old backups (keep 10 most recent)
    source "${REPO_DIR}/scripts/cleanup-backups.sh"
    cleanup_old_backups "${REPO_DIR}/.backups" 10

    log_section "Setup Complete!"
    echo ""
    log_ok "Project Agents environment is ready"
    echo ""
    log_info "Available workflow commands:"
    echo "  /plan <EPIC>      - Create planning document from Epic"
    echo "  /groom <EPIC>     - Create Jira issues from planning doc"
    echo "  /work <ISSUE>     - Implement issue through PR merge"
    echo "  /validate <ISSUE> - Validate deployed changes"
    echo "  /next             - Find next priority issue"
    echo "  /bug <desc>       - Report and create bug issue"
    echo "  /issue <desc>     - Create new issue"
    echo "  /audit <URL>      - Run UI compliance audit"
    echo ""
    log_info "Autonomous workflow (ralph-wiggum plugin):"
    echo "  /ralph-wiggum:ralph-loop \"<prompt>\" --completion-promise \"<text>\""
    echo "  /cancel-ralph     - Stop running ralph loop"
    echo ""
    log_info "tenant-specific ralph loop:"
    echo "  /ralph-wiggum:ralph-loop \"\$(cat .claude/ralph-prompts/gw-jira-workflow.md)\" \\"
    echo "    --max-iterations 20 --completion-promise \"BACKLOG CLEAR\""
    echo ""
    log_info "Start Claude Code in your project directory:"
    echo "  cd /path/to/your/project"
    echo "  claude"
    echo ""
    log_info "Then try: /next"
    echo ""
}

# Parse arguments
case "${1:-}" in
    --check|--status)
        show_status
        ;;
    --validate)
        validate_installation
        ;;
    --update-commands)
        update_commands
        ;;
    --configure-repos)
        configure_repos_only
        ;;
    --configure-agentdb)
        configure_agentdb_only
        ;;
    --configure-supergateway)
        configure_supergateway_only
        ;;
    --uninstall)
        uninstall
        ;;
    --help|-h)
        usage
        ;;
    *)
        main
        ;;
esac
