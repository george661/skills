# =============================================================================
# DEPRECATED: Use templates/.env.template instead
# =============================================================================
#
# This file is maintained for backwards compatibility.
# For new *-agents repositories, use: templates/.env.template
#
# The comprehensive template includes:
# - All tenant configuration options
# - AWS/Bedrock configuration
# - Jira/Bitbucket/Slack integration settings
# - Daemon configuration
# - Repository JSON configuration
# - Example configurations for project tenants
#
# =============================================================================

# Integration providers
ISSUE_TRACKER=jira          # Options: jira (github, linear planned)
VCS_PROVIDER=bitbucket      # Options: bitbucket (github, gitlab planned)

# Tenant identification
TENANT=your-tenant
TENANT_NAMESPACE=your-tenant
TENANT_PROJECT=YOUR-PROJECT-KEY

# Jira-specific (when ISSUE_TRACKER=jira)
JIRA_PROJECT_KEY=${TENANT_PROJECT}
JIRA_HOST=your-org.atlassian.net

# Bitbucket-specific (when VCS_PROVIDER=bitbucket)
BITBUCKET_WORKSPACE=your-workspace
BITBUCKET_REPOS=repo1,repo2,repo3

# AgentDB Central Configuration
# Set AGENTDB_USE_CENTRAL=true to use central store instead of local SQLite
AGENTDB_USE_CENTRAL=false
AGENTDB_ENDPOINT=YOUR_AGENTDB_URL
AGENTDB_AUTH_METHOD=api-key  # Options: api-key, sso
AGENTDB_API_KEY=             # Required when AGENTDB_AUTH_METHOD=api-key
